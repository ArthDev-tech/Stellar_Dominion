[node name="ResearchStatus" type="Label" parent="Margin/VBox/TopBar/HBox"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_colors/font_color = Color(0.85, 0.88, 1, 1)
theme_override_font_sizes/font_size = 14
text = "No active research"

[node name="ResearchProgress" type="ProgressBar" parent="Margin/VBox/TopBar/HBox"]
